  "keyFeatures": [
    "Edition lifecycle management (open, close, advance states)",
    "Team registration and coach assignment",
    "Match generation with unique rivalry constraints (no repeat matchups)",
    "Real-time scoring, match results, and leaderboard",
    "Volunteer management with role conflict validation (Judge/Referee)",
    "Project Room management with judge assignment",
    "Competition table and round scheduling",
    "HAL/HATEOAS hypermedia REST API",
    "Spring Security with role-based access control",
    "BDD tests with Cucumber/Gherkin",
    "Docker support with multi-stage builds"
  ],
  "publicApiSurface": [
    "GET /editions/{editionId} — Get edition details",
    "PATCH /editions/{editionId}/state — Advance edition lifecycle state",
    "POST /editions/{editionId}/teams/{teamId} — Register team to edition",
    "GET /editions/{editionId}/volunteers — List volunteers for an edition",
    "GET /editions/{editionId}/tables — List competition tables for an edition",
    "GET /matches — List matches",
    "POST /matches — Create a match",
    "GET /matches/search/findByTeam — Search matches by team",
    "GET /matches/filter — Filter matches with criteria",
    "POST /matchAssignments/assign — Assign match to table",
    "POST /matchAssignments/batch — Batch match assignment",
    "POST /matchResults/register — Register match score",
    "GET /leaderboards — Get leaderboard",
    "GET /leaderboards/editions/{editionId} — Get edition leaderboard",
    "POST /teams/assign-coach — Assign coach to team",
    "POST /project-rooms/assign-judge — Assign judge to project room",
    "GET /identity — Get current user identity",
    "POST /register — Register new user"
  ]
}
